# Hermes Vault Sync — Environment Configuration

# A long random string for signing session cookies
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Admin password for the /dashboard login screen
ADMIN_PASSWORD=change-me

# Server bind settings
HOST=0.0.0.0
PORT=8000

# SQLite database file path
DB_PATH=./hermes.db

# Fallback vault path used only if the database has no vault_path set yet
DEFAULT_VAULT_PATH=./vault
